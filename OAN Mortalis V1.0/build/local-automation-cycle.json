  "notificationPolicy": {
    "enabled": true,
    "notifyOnStatuses": [
      "hitl-required",
      "blocked"
    ],
    "bestEffortWindowsPopup": true,
    "popupTimeoutSeconds": 12,
    "onlyNotifyOnTransition": true
  },
  "seededGovernancePolicy": {
    "enabled": true,
    "attemptLocalPreflight": true,
    "ensureReadyOnCall": true,
    "startupWaitSeconds": 20,
    "hostEndpoint": "http://127.0.0.1:8181",
    "unreachableDisposition": "Deferred",
    "acceptedReadinessStatuses": [
      "ReadyForTelemetryStaging"
    ],
    "deferredReadinessStatuses": [
      "Borderline"
    ],
    "rejectedReadinessStatuses": [
      "NotReady"
    ]
  },
  "schedulerReconciliationPolicy": {
    "driftToleranceMinutes": 3
  },
  "retentionPolicy": {
    "keepReleaseCandidateBundles": 8,
    "keepDigestBundles": 8,
    "keepLongFormTaskMapRuns": 8,
    "keepBlockedEscalationBundles": 8,
    "keepNotificationBundles": 8,
