    "keepPublicationCadenceLedgerBundles": 8,
    "keepDownstreamRuntimeObservationBundles": 8,
    "keepMultiIntervalGovernanceBraidBundles": 8,
    "keepSchedulerExecutionReceiptBundles": 8,
    "keepUnattendedIntervalConcordanceBundles": 8,
    "keepStaleSurfaceContradictionWatchBundles": 8,
    "keepUnattendedProofCollapseBundles": 8,
    "keepDormantWindowLedgerBundles": 8,
    "keepSilentCadenceIntegrityBundles": 8,
    "keepLongFormPhaseWitnessBundles": 8,
    "keepLongFormWindowBoundaryBundles": 8,
    "keepAutonomousLongFormCollapseBundles": 8,
