{
  "schemaVersion": 1,
  "defaultConfiguration": "Release",
  "localReleaseCandidateCadenceHours": 6,
  "mandatoryHitlDigestCadenceHours": 24,
  "digestWindowHours": 24,
  "releaseCandidateOutputRoot": ".audit/runs/release-candidates",
  "digestOutputRoot": ".audit/runs/release-digests",
  "blockedEscalationOutputRoot": ".audit/runs/blocked-escalations",
  "notificationOutputRoot": ".audit/runs/notifications",
  "seededGovernanceOutputRoot": ".audit/runs/seeded-governance",
  "promotionGateOutputRoot": ".audit/runs/promotion-gates",
  "ciConcordanceOutputRoot": ".audit/runs/ci-concordance",
  "releaseRatificationOutputRoot": ".audit/runs/release-ratification",
  "seededPromotionReviewOutputRoot": ".audit/runs/seeded-promotion-review",
  "firstPublishIntentOutputRoot": ".audit/runs/first-publish-intent",
  "releaseHandshakeOutputRoot": ".audit/runs/release-handshake",
  "publishRequestEnvelopeOutputRoot": ".audit/runs/publish-request-envelopes",
  "postPublishEvidenceOutputRoot": ".audit/runs/post-publish-evidence",
  "seedBraidEscalationOutputRoot": ".audit/runs/seed-braid-escalations",
  "statePath": ".audit/state/local-automation-cycle.json",
  "retentionStatePath": ".audit/state/local-automation-retention-last-run.json",
  "blockedEscalationStatePath": ".audit/state/local-automation-blocked-escalation-last-run.json",
  "notificationStatePath": ".audit/state/local-automation-notification-last-run.json",
  "seededGovernanceStatePath": ".audit/state/local-automation-seeded-governance-last-run.json",
  "schedulerReconciliationStatePath": ".audit/state/local-automation-scheduler-reconciliation-last-run.json",
  "cmeConsolidationStatePath": ".audit/state/local-automation-cme-consolidation-state.json",
  "promotionGateStatePath": ".audit/state/local-automation-promotion-gate-last-run.json",
  "ciConcordanceStatePath": ".audit/state/local-automation-ci-concordance-last-run.json",
  "releaseRatificationStatePath": ".audit/state/local-automation-release-ratification-last-run.json",
  "seededPromotionReviewStatePath": ".audit/state/local-automation-seeded-promotion-review-last-run.json",
  "firstPublishIntentStatePath": ".audit/state/local-automation-first-publish-intent-last-run.json",
  "releaseHandshakeStatePath": ".audit/state/local-automation-release-handshake-last-run.json",
  "publishRequestEnvelopeStatePath": ".audit/state/local-automation-publish-request-envelope-last-run.json",
  "postPublishEvidenceStatePath": ".audit/state/local-automation-post-publish-evidence-last-run.json",
  "seedBraidEscalationStatePath": ".audit/state/local-automation-seed-braid-escalation-last-run.json",
  "notificationPolicy": {
    "enabled": true,
    "notifyOnStatuses": [
      "hitl-required",
      "blocked"
    ],
    "bestEffortWindowsPopup": true,
    "popupTimeoutSeconds": 12,
    "onlyNotifyOnTransition": true
  },
  "seededGovernancePolicy": {
    "enabled": true,
    "attemptLocalPreflight": true,
    "hostEndpoint": "http://127.0.0.1:8181",
    "unreachableDisposition": "Deferred",
    "acceptedReadinessStatuses": [
      "ReadyForTelemetryStaging"
    ],
    "deferredReadinessStatuses": [
      "Borderline"
    ],
    "rejectedReadinessStatuses": [
      "NotReady"
    ]
  },
  "schedulerReconciliationPolicy": {
    "driftToleranceMinutes": 3
  },
  "retentionPolicy": {
    "keepReleaseCandidateBundles": 8,
    "keepDigestBundles": 8,
    "keepLongFormTaskMapRuns": 8,
    "keepBlockedEscalationBundles": 8,
    "keepNotificationBundles": 8,
    "keepSeededGovernanceBundles": 8,
    "keepPromotionGateBundles": 8,
    "keepCiConcordanceBundles": 8,
    "keepReleaseRatificationBundles": 8,
    "keepSeededPromotionReviewBundles": 8,
    "keepFirstPublishIntentBundles": 8,
    "keepReleaseHandshakeBundles": 8,
    "keepPublishRequestEnvelopeBundles": 8,
    "keepPostPublishEvidenceBundles": 8,
    "keepSeedBraidEscalationBundles": 8,
    "preserveReferencedBundles": true
  },
  "mechanicalContinuationStatuses": [
    "candidate-ready",
    "hitl-required"
  ],
  "blockedStatus": "blocked"
}
