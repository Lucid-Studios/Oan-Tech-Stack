    "keepQueuedTaskMapPromotionBundles": 8,
    "keepRuntimeDeployabilityEnvelopeBundles": 8,
    "keepSanctuaryRuntimeReadinessBundles": 8,
    "keepRuntimeWorkSurfaceAdmissibilityBundles": 8,
    "preserveReferencedBundles": true
